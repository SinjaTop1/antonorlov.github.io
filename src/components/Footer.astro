<style>
	footer {
		padding: 3rem 0;
		border-top: 1px solid var(--border);
	}
	.footer-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.copyright {
		font-size: 0.85rem;
		color: var(--text-tertiary);
	}
	.social-links {
		display: flex;
		gap: 1rem;
	}
	.social-links a {
		color: var(--text-tertiary);
		display: flex;
		align-items: center;
		transition: color var(--transition);
	}
	.social-links a:hover {
		color: var(--text);
		opacity: 1;
	}
	@media (max-width: 480px) {
		.footer-inner {
			flex-direction: column;
			gap: 1rem;
		}
	}
</style>
