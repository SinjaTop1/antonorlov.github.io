---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<main>
			<section class="hero">
				<div class="container hero-inner">
					<div class="hero-text">
						<h1>Anton Orlov</h1>
						<p class="hero-tagline">
							Founder & entrepreneur building products that simplify everyday life.
							BA candidate at Webster University Vienna.
						</p>
						<p class="hero-sub">
							Currently leading <a href="https://petpassvienna.com" target="_blank" class="link">Pet Pass Vienna</a>.
							Based in Vienna.
						</p>
						<div class="hero-actions">
							<a href="/cv" class="btn-primary">View CV</a>
							<a href="/about" class="btn-ghost">About me</a>
						</div>
						<div class="hero-social">
							<a href="https://www.linkedin.com/in/anton-orlov-b16126269/" target="_blank" aria-label="LinkedIn">
								<svg viewBox="0 0 24 24" width="20" height="20"><path fill="currentColor" d="M19 0h-14c-2.76 0-5 2.24-5 5v14c0 2.76 2.24 5 5 5h14c2.76 0 5-2.24 5-5v-14c0-2.76-2.24-5-5-5zm-11.5 20h-3v-9h3v9zm-1.5-10.25c-.966 0-1.75-.784-1.75-1.75s.784-1.75 1.75-1.75 1.75.784 1.75 1.75-.784 1.75-1.75 1.75zm13 10.25h-3v-4.5c0-1.08-.02-2.47-1.5-2.47-1.5 0-1.73 1.17-1.73 2.38v4.59h-3v-9h2.89v1.23h.04c.403-.76 1.387-1.56 2.855-1.56 3.053 0 3.62 2.008 3.62 4.62v4.71z"/></svg>
							</a>
							<a href="https://www.instagram.com/orochiyo" target="_blank" aria-label="Instagram">
								<svg viewBox="0 0 24 24" width="20" height="20"><path fill="currentColor" d="M12 2.2c3.1 0 3.5 0 4.7.1 1.2.1 1.9.3 2.3.5.6.2 1 .5 1.5 1 .5.5.8.9 1 1.5.2.4.4 1.1.5 2.3.1 1.2.1 1.6.1 4.7s0 3.5-.1 4.7c-.1 1.2-.3 1.9-.5 2.3-.2.6-.5 1-.9 1.5-.5.5-.9.8-1.5 1-.4.2-1.1.4-2.3.5-1.2.1-1.6.1-4.7.1s-3.5 0-4.7-.1c-1.2-.1-1.9-.3-2.3-.5-.6-.2-1-.5-1.5-1-.5-.5-.8-.9-1-1.5-.2-.4-.4-1.1-.5-2.3-.1-1.2-.1-1.6-.1-4.7s0-3.5.1-4.7c.1-1.2.3-1.9.5-2.3.2-.6.5-1 1-1.5.5-.5.9-.8 1.5-1 .4-.2 1.1-.4 2.3-.5 1.2-.1 1.6-.1 4.7-.1M12 0C8.741 0 8.332.015 7.052.072 5.771.129 4.807.308 4.042.633c-.78.337-1.44.787-2.102 1.45C1.278 2.747.828 3.407.49 4.187.166 4.952-.013 5.915-.07 7.196-.127 8.476-.142 8.885-.142 12c0 3.115.015 3.524.072 4.804.057 1.281.236 2.244.561 3.01.337.78.787 1.44 1.45 2.102.662.662 1.322 1.112 2.102 1.45.766.325 1.73.504 3.01.561 1.28.057 1.689.072 4.804.072s3.524-.015 4.804-.072c1.281-.057 2.244-.236 3.01-.561.78-.337 1.44-.787 2.102-1.45.662-.662 1.112-1.322 1.45-2.102.325-.766.504-1.73.561-3.01.057-1.28.072-1.689.072-4.804s-.015-3.524-.072-4.804c-.057-1.281-.236-2.244-.561-3.01-.337-.78-.787-1.44-1.45-2.102-.662-.662-1.322-1.112-2.102-1.45-.766-.325-1.73-.504-3.01-.561C15.524.015 15.115 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zm0 10.162a3.999 3.999 0 1 1 0-8 3.999 3.999 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0-2.88 1.44 1.44 0 0 0 0 2.88z"/></svg>
							</a>
							<a href="mailto:orlovantonle@gmail.com" aria-label="Email">
								<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
							</a>
						</div>
					</div>
					<div class="hero-photo">
						<img src="/imageytr.png" alt="Anton Orlov" />
					</div>
				</div>
			</section>

			<section id="projects" class="projects">
				<div class="container">
					<p class="label">Projects</p>

					<a href="https://petpassvienna.com" target="_blank" class="project-card clickable">
						<div class="project-card-inner">
							<div class="project-meta">
								<span class="badge">Current</span>
								<span class="project-year">2025</span>
							</div>
							<h2>Pet Pass Vienna</h2>
							<p>
								A preventive care membership for pet owners. Vaccines, check-ups, dental care,
								deworming, tick protection, curated gift boxes, and smart reminders — all in one product.
								Your job: love your pet. We handle the rest.
							</p>
							<span class="card-link">
								petpassvienna.com
								<svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M3.5 1H11V8.5M11 1L1 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
							</span>
						</div>
					</a>

					<div class="project-card">
						<div class="project-card-inner">
							<div class="project-meta">
								<span class="badge badge-past">Previous</span>
								<span class="project-year">2025</span>
							</div>
							<h2>BSC</h2>
							<p>
								Business-learning events and mentorship programs connecting students with top entrepreneurs.
								Launched events for 100+ students and developed a mentorship course with AI-powered analytics.
							</p>
						</div>
					</div>

					<div class="project-card">
						<div class="project-card-inner">
							<div class="project-meta">
								<span class="badge badge-past">Previous</span>
								<span class="project-year">2022 — 2023</span>
							</div>
							<h2>Olive Crown Estate</h2>
							<p>
								Boutique real estate agency in Cyprus specializing in residential sales and rentals.
								Built from scratch — implemented CRM systems, automated workflows, managed client relationships,
								and coordinated remote teams.
							</p>
						</div>
					</div>
				</div>
			</section>

			<section class="approach">
				<div class="container">
					<div class="approach-grid">
						<div class="approach-item fade-in">
							<h3>Simplify</h3>
							<p>Find the real problem. Strip away everything that doesn't matter. Build what does.</p>
						</div>
						<div class="approach-item fade-in">
							<h3>Execute</h3>
							<p>Ideas are cheap. I care about shipping, learning from users, and iterating fast.</p>
						</div>
						<div class="approach-item fade-in">
							<h3>Empower</h3>
							<p>The best work comes from teams that trust each other. I build those environments.</p>
						</div>
					</div>
				</div>
			</section>

			<section class="cta">
				<div class="container cta-inner">
					<h2>Let's connect</h2>
					<p>Open to conversations about startups, product, or collaboration.</p>
					<div class="cta-links">
						<a href="mailto:orlovantonle@gmail.com">Email<svg width="11" height="11" viewBox="0 0 12 12" fill="none"><path d="M3.5 1H11V8.5M11 1L1 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
						<a href="https://www.linkedin.com/in/anton-orlov-b16126269/" target="_blank">LinkedIn<svg width="11" height="11" viewBox="0 0 12 12" fill="none"><path d="M3.5 1H11V8.5M11 1L1 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
						<a href="https://www.instagram.com/orochiyo" target="_blank">Instagram<svg width="11" height="11" viewBox="0 0 12 12" fill="none"><path d="M3.5 1H11V8.5M11 1L1 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
					</div>
				</div>
			</section>
		</main>

		<Footer />

		<script is:inline>
			document.addEventListener("DOMContentLoaded", function () {
				var observer = new IntersectionObserver(
					function (entries) {
						entries.forEach(function (entry) {
							if (entry.isIntersecting) entry.target.classList.add("visible");
						});
					},
					{ threshold: 0.15, rootMargin: "0px 0px -40px 0px" }
				);
				document.querySelectorAll(".fade-in").forEach(function (el) { observer.observe(el); });
			});
		</script>

		<style>
			.hero {
				min-height: 100vh;
				display: flex;
				align-items: center;
				padding-top: 60px;
			}
			.hero-inner {
				display: grid;
				grid-template-columns: 1.1fr 0.9fr;
				gap: 4rem;
				align-items: center;
				padding: 4rem 0;
			}
			.hero h1 { margin-bottom: 1rem; }
			.hero-tagline {
				font-size: 1.15rem;
				color: var(--text-secondary);
				line-height: 1.7;
				margin-bottom: 0.75rem;
				max-width: 460px;
			}
			.hero-sub {
				font-size: 0.95rem;
				color: var(--text-tertiary);
				max-width: 420px;
				margin-bottom: 2rem;
			}
			.link {
				color: var(--text);
				font-weight: 500;
				text-decoration: underline;
				text-decoration-color: var(--border);
				text-underline-offset: 3px;
			}
			.link:hover { text-decoration-color: var(--text); opacity: 1; }
			.hero-actions {
				display: flex;
				gap: 0.75rem;
				margin-bottom: 2rem;
			}
			.btn-primary, .btn-ghost {
				display: inline-flex;
				align-items: center;
				padding: 0.65rem 1.35rem;
				border-radius: 100px;
				font-size: 0.875rem;
				font-weight: 500;
				transition: all var(--transition);
			}
			.btn-primary { background: var(--text); color: #fff; }
			.btn-primary:hover { background: var(--accent-hover); opacity: 1; }
			.btn-ghost { color: var(--text); border: 1px solid var(--border); background: transparent; }
			.btn-ghost:hover { border-color: var(--text); opacity: 1; }
			.hero-social { display: flex; gap: 0.75rem; }
			.hero-social a {
				color: var(--text-tertiary);
				display: flex;
				transition: color var(--transition);
			}
			.hero-social a:hover { color: var(--text); opacity: 1; }
			.hero-photo { display: flex; justify-content: flex-end; }
			.hero-photo img {
				width: 100%;
				max-width: 380px;
				border-radius: var(--radius);
				object-fit: cover;
			}

			.projects {
				padding: 6rem 0;
				background: var(--bg-alt);
				border-top: 1px solid var(--border);
			}
			.label {
				font-size: 0.75rem;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.12em;
				color: var(--text-tertiary);
				margin-bottom: 2rem;
			}
			.project-card {
				display: block;
				border: 1px solid var(--border);
				border-radius: var(--radius);
				padding: 2rem;
				margin-bottom: 0.75rem;
				transition: all var(--transition);
				background: var(--bg);
				text-decoration: none;
				color: inherit;
			}
			.project-card.clickable:hover {
				border-color: var(--text);
				transform: translateY(-2px);
				box-shadow: 0 8px 30px rgba(0, 0, 0, 0.06);
				opacity: 1;
			}
			.project-meta {
				display: flex;
				align-items: center;
				gap: 0.75rem;
				margin-bottom: 0.6rem;
			}
			.badge {
				font-size: 0.65rem;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				padding: 0.15rem 0.55rem;
				border-radius: 100px;
				background: var(--text);
				color: #fff;
			}
			.badge-past {
				background: transparent;
				color: var(--text-tertiary);
				border: 1px solid var(--border);
			}
			.project-year { font-size: 0.8rem; color: var(--text-tertiary); }
			.project-card h2 { font-size: 1.25rem; margin-bottom: 0.4rem; }
			.project-card p { font-size: 0.9rem; max-width: 600px; line-height: 1.7; }
			.card-link {
				display: inline-flex;
				align-items: center;
				gap: 0.3rem;
				margin-top: 0.75rem;
				font-size: 0.85rem;
				font-weight: 500;
				color: var(--text-tertiary);
				transition: color var(--transition);
			}
			.project-card.clickable:hover .card-link { color: var(--text); }
			.card-link svg { transition: transform var(--transition); }
			.project-card.clickable:hover .card-link svg { transform: translate(1px, -1px); }

			.approach {
				padding: 6rem 0;
				border-top: 1px solid var(--border);
			}
			.approach-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 3rem;
			}
			.approach-item {
				opacity: 0;
				transform: translateY(16px);
				transition: opacity 0.5s ease, transform 0.5s ease;
			}
			.approach-item.visible { opacity: 1; transform: translateY(0); }
			.approach-item:nth-child(2) { transition-delay: 0.08s; }
			.approach-item:nth-child(3) { transition-delay: 0.16s; }
			.approach-item h3 { margin-bottom: 0.5rem; font-size: 1.1rem; }
			.approach-item p { font-size: 0.9rem; line-height: 1.7; }

			.cta {
				padding: 5rem 0 6rem;
				background: var(--bg-alt);
				border-top: 1px solid var(--border);
			}
			.cta-inner { text-align: center; }
			.cta h2 { margin-bottom: 0.5rem; }
			.cta > .container > p {
				color: var(--text-secondary);
				font-size: 0.95rem;
				margin-bottom: 1.5rem;
			}
			.cta-links { display: flex; justify-content: center; gap: 1.5rem; }
			.cta-links a {
				display: inline-flex;
				align-items: center;
				gap: 0.3rem;
				font-size: 0.9rem;
				font-weight: 500;
				color: var(--text-secondary);
				transition: color var(--transition);
			}
			.cta-links a:hover { color: var(--text); opacity: 1; }
			.cta-links a svg { transition: transform var(--transition); }
			.cta-links a:hover svg { transform: translate(1px, -1px); }

			@media (max-width: 768px) {
				.hero-inner {
					grid-template-columns: 1fr;
					gap: 2.5rem;
					text-align: center;
					padding: 3rem 0;
				}
				.hero-tagline, .hero-sub { max-width: 100%; }
				.hero-actions { justify-content: center; }
				.hero-social { justify-content: center; }
				.hero-photo { order: -1; justify-content: center; }
				.hero-photo img { max-width: 260px; }
				.projects, .approach, .cta { padding: 4rem 0; }
				.project-card { padding: 1.5rem; }
				.approach-grid { grid-template-columns: 1fr; gap: 2rem; }
				.cta-links { flex-direction: column; align-items: center; gap: 0.75rem; }
			}
		</style>
	</body>
</html>
