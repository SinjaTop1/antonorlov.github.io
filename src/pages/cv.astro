---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<BaseHead title="CV — Anton Orlov" description="Digital CV of Anton Orlov — founder, entrepreneur, and BA candidate at Webster University Vienna." />
	</head>
	<body>
		<Header />

		<main>
			<section class="cv-header">
				<div class="container">
					<div class="cv-top">
						<div>
							<h1>Anton Orlov</h1>
							<p class="cv-role">Founder & Entrepreneur</p>
						</div>
						<div class="cv-contact">
							<a href="mailto:orlovantonle@gmail.com">Email</a>
							<a href="https://www.linkedin.com/in/anton-orlov-b16126269/" target="_blank">LinkedIn</a>
							<span class="cv-location">Vienna, Austria</span>
						</div>
					</div>
					<p class="cv-summary">
						Enthusiastic BA candidate at Webster University Vienna with entrepreneurial experience.
						Proven ability to design processes, lead teams, and build products from scratch.
						Currently leading Pet Pass Vienna — simplifying preventive pet care for dog and cat owners.
					</p>
				</div>
			</section>

			<section class="cv-section">
				<div class="container">
					<h2>Experience</h2>
					<div class="cv-timeline">

						<div class="cv-entry">
							<div class="cv-entry-header">
								<div>
									<h3>Founder & CEO</h3>
									<p class="cv-company">
										<a href="https://petpassvienna.com" target="_blank">Pet Pass Vienna</a>
										<span class="cv-loc">Vienna, Austria</span>
									</p>
								</div>
								<span class="cv-date">2025 — Present</span>
							</div>
							<p class="cv-desc">
								Building a preventive pet care membership for dog and cat owners in Vienna —
								all-in-one product covering vaccines, check-ups, dental care, deworming, tick protection,
								curated gift boxes, and smart reminders.
							</p>
							<ul class="cv-highlights">
								<li>Developed the product concept and go-to-market strategy from scratch</li>
								<li>Personally visited and vetted nearly every vet clinic in Vienna to build a trusted network</li>
								<li>Built partnerships with local pet brands for curated subscription boxes</li>
								<li>Designed a founder-first membership launch model (100 founding spots)</li>
							</ul>
						</div>

						<div class="cv-entry">
							<div class="cv-entry-header">
								<div>
									<h3>Co-Founder & CEO</h3>
									<p class="cv-company">
										BSC
										<span class="cv-loc">Vienna, Austria</span>
									</p>
								</div>
								<span class="cv-date">Jan 2025</span>
							</div>
							<p class="cv-desc">
								Leading the development of innovative business-learning events and mentorship programs
								connecting students with top entrepreneurs.
							</p>
							<ul class="cv-highlights">
								<li>Launched interactive business events for 100+ students with 95% satisfaction rate</li>
								<li>Developed 4–5 week mentorship course with AI-powered analytics and practical business building</li>
								<li>Led cross-functional team of 5, reducing planning time by 30% through streamlined processes</li>
								<li>Organized end-to-end event operations including vendor sourcing, scheduling, and marketing</li>
							</ul>
						</div>

						<div class="cv-entry">
							<div class="cv-entry-header">
								<div>
									<h3>Founder & Managing Director</h3>
									<p class="cv-company">
										Olive Crown Estate
										<span class="cv-loc">Girne, Cyprus</span>
									</p>
								</div>
								<span class="cv-date">Mar 2022 — Mar 2023</span>
							</div>
							<p class="cv-desc">
								Established and operated a boutique real estate agency specializing
								in residential property sales and rentals.
							</p>
							<ul class="cv-highlights">
								<li>Built successful property sales and rental business from the ground up</li>
								<li>Implemented CRM and automated workflow systems, cutting administrative overhead by 40%</li>
								<li>Negotiated contracts and managed complex client relationships</li>
								<li>Coordinated remote and local teams, fostering collaborative culture</li>
							</ul>
						</div>

					</div>
				</div>
			</section>

			<section class="cv-section cv-section-alt">
				<div class="container">
					<h2>Skills</h2>
					<div class="cv-skills">
						<div class="cv-skill-group">
							<h3>Leadership</h3>
							<ul>
								<li>Team building & management</li>
								<li>Cross-functional coordination</li>
								<li>Stakeholder communication</li>
								<li>Objective setting & mentoring</li>
							</ul>
						</div>
						<div class="cv-skill-group">
							<h3>Product & Business</h3>
							<ul>
								<li>0-to-1 product development</li>
								<li>Go-to-market strategy</li>
								<li>Process optimization & automation</li>
								<li>Partnership development</li>
							</ul>
						</div>
						<div class="cv-skill-group">
							<h3>Technical</h3>
							<ul>
								<li>AI & data literacy</li>
								<li>CRM & workflow automation</li>
								<li>Digital marketing</li>
								<li>Financial analysis</li>
							</ul>
						</div>
					</div>
				</div>
			</section>

			<section class="cv-section">
				<div class="container">
					<div class="cv-two-col">
						<div>
							<h2>Education</h2>
							<div class="cv-timeline">
								<div class="cv-entry">
									<div class="cv-entry-header">
										<div>
											<h3>Bachelor of Business Administration</h3>
											<p class="cv-company">Webster University Vienna</p>
										</div>
										<span class="cv-date">Expected May 2026</span>
									</div>
									<p class="cv-desc cv-gpa">GPA: 3.5 / 4.0</p>
									<div class="cv-coursework">
										<span>Financial Analysis</span>
										<span>Business Process Management</span>
										<span>Data Analytics</span>
										<span>AI in Business</span>
									</div>
								</div>
								<div class="cv-entry">
									<div class="cv-entry-header">
										<div>
											<h3>Finance Studies</h3>
											<p class="cv-company">Financial University, Moscow</p>
										</div>
										<span class="cv-date">2019 — 2022</span>
									</div>
									<p class="cv-desc">Completed three years toward Bachelor in Finance with foundational expertise in corporate finance, risk management, and financial modeling.</p>
								</div>
							</div>
						</div>
						<div>
							<h2>Languages</h2>
							<div class="cv-languages">
								<div class="cv-lang">
									<span>Russian</span>
									<span class="cv-lang-level">Native</span>
								</div>
								<div class="cv-lang">
									<span>English</span>
									<span class="cv-lang-level">Fluent</span>
								</div>
								<div class="cv-lang">
									<span>German</span>
									<span class="cv-lang-level">Basic</span>
								</div>
								<div class="cv-lang">
									<span>Spanish</span>
									<span class="cv-lang-level">Basic</span>
								</div>
							</div>

							<h2 class="mt">Interests</h2>
							<div class="cv-interests">
								<div class="cv-interest">
									<span class="cv-interest-label">Fitness & Sports</span>
									<p>Gym, climbing, combat sports</p>
								</div>
								<div class="cv-interest">
									<span class="cv-interest-label">AI Community</span>
									<p>Attendee and volunteer at Vienna AI meetups</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<section class="cv-footer-section">
				<div class="container cv-footer-inner">
					<p>Interested in working together?</p>
					<div class="cv-footer-links">
						<a href="mailto:orlovantonle@gmail.com" class="cv-cta">
							Email me
						</a>
						<a href="https://www.linkedin.com/in/anton-orlov-b16126269/" target="_blank" class="cv-cta cv-cta-ghost">
							LinkedIn
							<svg width="11" height="11" viewBox="0 0 12 12" fill="none"><path d="M3.5 1H11V8.5M11 1L1 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
						</a>
					</div>
				</div>
			</section>
		</main>

		<Footer />

		<style>
			.cv-header {
				padding-top: calc(60px + 4rem);
				padding-bottom: 3rem;
				border-bottom: 1px solid var(--border);
			}
			.cv-top {
				display: flex;
				justify-content: space-between;
				align-items: flex-start;
				margin-bottom: 1.5rem;
				gap: 2rem;
			}
			.cv-header h1 {
				font-size: clamp(2rem, 4vw, 2.75rem);
				margin-bottom: 0.25rem;
			}
			.cv-role {
				font-size: 1.05rem;
				color: var(--text-secondary);
				font-weight: 500;
			}
			.cv-contact {
				display: flex;
				align-items: center;
				gap: 1.25rem;
				flex-shrink: 0;
			}
			.cv-contact a {
				font-size: 0.875rem;
				font-weight: 500;
				color: var(--text-secondary);
				transition: color var(--transition);
			}
			.cv-contact a:hover { color: var(--text); opacity: 1; }
			.cv-location {
				font-size: 0.875rem;
				color: var(--text-tertiary);
			}
			.cv-summary {
				font-size: 1rem;
				max-width: 660px;
				line-height: 1.75;
			}

			.cv-section {
				padding: 3rem 0;
				border-bottom: 1px solid var(--border);
			}
			.cv-section-alt { background: var(--bg-alt); }
			.cv-section h2 {
				font-size: 0.75rem;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.12em;
				color: var(--text-tertiary);
				margin-bottom: 1.75rem;
			}

			.cv-timeline {
				display: flex;
				flex-direction: column;
				gap: 2.5rem;
			}
			.cv-entry-header {
				display: flex;
				justify-content: space-between;
				align-items: flex-start;
				margin-bottom: 0.5rem;
				gap: 1rem;
			}
			.cv-entry h3 {
				font-size: 1.05rem;
				margin-bottom: 0.1rem;
			}
			.cv-company {
				font-size: 0.9rem;
				color: var(--text-secondary);
			}
			.cv-company a {
				color: var(--text-secondary);
				text-decoration: underline;
				text-decoration-color: var(--border);
				text-underline-offset: 3px;
			}
			.cv-company a:hover { color: var(--text); text-decoration-color: var(--text); opacity: 1; }
			.cv-loc {
				color: var(--text-tertiary);
			}
			.cv-loc::before {
				content: '·';
				margin: 0 0.4rem;
			}
			.cv-date {
				font-size: 0.8rem;
				color: var(--text-tertiary);
				white-space: nowrap;
				padding-top: 0.2rem;
			}
			.cv-desc {
				font-size: 0.9rem;
				margin-bottom: 0.75rem;
				max-width: 600px;
			}
			.cv-gpa {
				font-weight: 500;
				color: var(--text);
				margin-bottom: 0.75rem;
			}
			.cv-highlights {
				list-style: none;
				display: flex;
				flex-direction: column;
				gap: 0.4rem;
			}
			.cv-highlights li {
				font-size: 0.875rem;
				color: var(--text-secondary);
				padding-left: 1.1rem;
				position: relative;
			}
			.cv-highlights li::before {
				content: '';
				position: absolute;
				left: 0;
				top: 0.55em;
				width: 4px;
				height: 4px;
				border-radius: 50%;
				background: var(--border);
			}

			.cv-coursework {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4rem;
			}
			.cv-coursework span {
				font-size: 0.8rem;
				padding: 0.2rem 0.65rem;
				border-radius: 100px;
				border: 1px solid var(--border);
				color: var(--text-secondary);
			}

			.cv-skills {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 2.5rem;
			}
			.cv-skill-group h3 {
				font-size: 0.95rem;
				margin-bottom: 0.75rem;
			}
			.cv-skill-group ul {
				list-style: none;
				display: flex;
				flex-direction: column;
				gap: 0.4rem;
			}
			.cv-skill-group li {
				font-size: 0.875rem;
				color: var(--text-secondary);
			}

			.cv-two-col {
				display: grid;
				grid-template-columns: 1.2fr 0.8fr;
				gap: 4rem;
			}
			.cv-two-col h2 {
				font-size: 0.75rem;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.12em;
				color: var(--text-tertiary);
				margin-bottom: 1.75rem;
			}
			.mt { margin-top: 2.5rem; }
			.cv-languages {
				display: flex;
				flex-direction: column;
				gap: 0.6rem;
			}
			.cv-lang {
				display: flex;
				justify-content: space-between;
				align-items: center;
				padding-bottom: 0.6rem;
				border-bottom: 1px solid var(--border);
			}
			.cv-lang span:first-child {
				font-size: 0.9rem;
				font-weight: 500;
			}
			.cv-lang-level {
				font-size: 0.8rem;
				color: var(--text-tertiary);
			}
			.cv-interests {
				display: flex;
				flex-direction: column;
				gap: 1rem;
			}
			.cv-interest-label {
				font-size: 0.9rem;
				font-weight: 500;
				display: block;
				margin-bottom: 0.15rem;
			}
			.cv-interest p {
				font-size: 0.85rem;
				color: var(--text-tertiary);
			}

			.cv-footer-section {
				padding: 3.5rem 0 4.5rem;
			}
			.cv-footer-inner { text-align: center; }
			.cv-footer-inner > p {
				font-size: 1.05rem;
				margin-bottom: 1.25rem;
			}
			.cv-footer-links {
				display: flex;
				justify-content: center;
				gap: 0.75rem;
			}
			.cv-cta {
				display: inline-flex;
				align-items: center;
				gap: 0.35rem;
				font-size: 0.875rem;
				font-weight: 500;
				padding: 0.6rem 1.25rem;
				border-radius: 100px;
				background: var(--text);
				color: #fff;
				transition: all var(--transition);
			}
			.cv-cta:hover { background: var(--accent-hover); opacity: 1; }
			.cv-cta-ghost {
				background: transparent;
				color: var(--text);
				border: 1px solid var(--border);
			}
			.cv-cta-ghost:hover { border-color: var(--text); background: transparent; }
			.cv-cta svg { transition: transform var(--transition); }
			.cv-cta:hover svg { transform: translate(1px, -1px); }

			@media (max-width: 768px) {
				.cv-header { padding-top: calc(60px + 2.5rem); }
				.cv-top { flex-direction: column; gap: 1rem; }
				.cv-contact { flex-wrap: wrap; gap: 0.75rem; }
				.cv-section { padding: 2.5rem 0; }
				.cv-skills { grid-template-columns: 1fr; gap: 2rem; }
				.cv-two-col { grid-template-columns: 1fr; gap: 2.5rem; }
				.cv-entry-header { flex-direction: column; gap: 0.15rem; }
			}

			@media print {
				header, footer, .cv-footer-section { display: none; }
				.cv-header { padding-top: 0; }
				.cv-section { break-inside: avoid; }
				body { font-size: 13px; }
			}
		</style>
	</body>
</html>
