---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<BaseHead title="About — Anton Orlov" description="Entrepreneur, founder, BA candidate at Webster University Vienna." />
	</head>
	<body>
		<Header />

		<main>
			<section class="about-hero">
				<div class="container about-grid">
					<div class="about-photo">
						<img src="/imageytr.png" alt="Anton Orlov" />
					</div>
					<div class="about-text">
						<p class="label">About</p>
						<h1>I build things that simplify life.</h1>
						<div class="about-body">
							<p>
								I'm Anton — a founder and entrepreneur based in Vienna, currently finishing my BA in
								Business Administration at Webster University Vienna. I thrive on turning ideas into
								real products that solve real problems.
							</p>
							<p>
								Right now I'm fully focused on <a href="https://petpassvienna.com" target="_blank" class="link">Pet Pass Vienna</a>,
								a membership that puts all preventive pet care into one product — vaccines, check-ups,
								dental care, deworming, tick protection, and curated gift boxes. One subscription, zero stress.
							</p>
							<p>
								Before this, I co-founded <strong>BSC</strong> — business-learning events and mentorship
								programs connecting students with top entrepreneurs in Vienna. And earlier,
								I built <strong>Olive Crown Estate</strong>, a boutique real estate agency in Cyprus,
								from scratch — learning to implement systems, manage clients, and lead remote teams.
							</p>
							<p>
								My approach is straightforward: identify a real friction, assemble the right people,
								move fast, and keep iterating until it works. I care about craft, clarity, and building
								environments where people do their best work.
							</p>
						</div>
						<div class="about-actions">
							<a href="/cv" class="btn-primary">View my CV</a>
							<a href="mailto:orlovantonle@gmail.com" class="btn-ghost">Email me</a>
						</div>
					</div>
				</div>
			</section>
		</main>

		<Footer />

		<style>
			.about-hero {
				padding-top: calc(60px + 4rem);
				padding-bottom: 6rem;
				min-height: calc(100vh - 80px);
				display: flex;
				align-items: center;
			}
			.about-grid {
				display: grid;
				grid-template-columns: 0.85fr 1.15fr;
				gap: 4rem;
				align-items: center;
			}
			.about-photo img {
				width: 100%;
				border-radius: var(--radius);
				object-fit: cover;
			}
			.label {
				font-size: 0.75rem;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.12em;
				color: var(--text-tertiary);
				margin-bottom: 0.75rem;
			}
			.about-text h1 {
				margin-bottom: 1.75rem;
				font-size: clamp(1.8rem, 3.5vw, 2.5rem);
			}
			.about-body p {
				font-size: 1rem;
				margin-bottom: 1.25rem;
				line-height: 1.8;
			}
			.about-body p:last-child { margin-bottom: 0; }
			.link {
				color: var(--text);
				font-weight: 500;
				text-decoration: underline;
				text-decoration-color: var(--border);
				text-underline-offset: 3px;
			}
			.link:hover { text-decoration-color: var(--text); opacity: 1; }
			.about-actions {
				display: flex;
				gap: 0.75rem;
				margin-top: 2rem;
			}
			.btn-primary, .btn-ghost {
				display: inline-flex;
				align-items: center;
				gap: 0.35rem;
				padding: 0.65rem 1.35rem;
				border-radius: 100px;
				font-size: 0.875rem;
				font-weight: 500;
				transition: all var(--transition);
			}
			.btn-primary { background: var(--text); color: #fff; }
			.btn-primary:hover { background: var(--accent-hover); opacity: 1; }
			.btn-ghost { color: var(--text); border: 1px solid var(--border); background: transparent; }
			.btn-ghost:hover { border-color: var(--text); opacity: 1; }

			@media (max-width: 768px) {
				.about-hero {
					padding-top: calc(60px + 2.5rem);
					padding-bottom: 4rem;
					min-height: auto;
				}
				.about-grid {
					grid-template-columns: 1fr;
					gap: 2.5rem;
					text-align: center;
				}
				.about-photo img {
					max-width: 280px;
					margin: 0 auto;
				}
				.about-actions { justify-content: center; }
			}
		</style>
	</body>
</html>
